# Supabase — copie para .env e preencha com as credenciais do seu projeto.
# Encontre em: Supabase Dashboard > Project Settings > API
# São valores públicos (anon/publishable), seguros para o bundle do cliente.
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
